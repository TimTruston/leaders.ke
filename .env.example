# ─── Database ──────────────────────────────────────────────────────────────
# Local development environment. Real secrets stay empty until you have them;
# the app degrades gracefully into mock mode when integration creds are absent.
DATABASE_URL="postgresql://user@localhost:5432/leaders_ke"

# ─── Platform ──────────────────────────────────────────────────────────────
# Public base URL of the deployment; used to build M-Pesa CallbackURL + wa.me links.
PUBLIC_BASE_URL="http://localhost:5111"

# ─── Safaricom Daraja (M-Pesa Express / STK Push) ───────────────────────────
MPESA_ENV="sandbox"
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_SHORTCODE="174379"
MPESA_PASSKEY=""
MPESA_CALLBACK_PATH="/api/v1/payments/callback"

# ─── Daraja B2C (provider payouts) ─────────────────────────────────────────
# Separate initiator credentials from the Daraja portal (API user / security credential).
# The security credential is the initiator password RSA-encrypted with Daraja's public cert.
MPESA_B2C_INITIATOR_NAME=""
MPESA_B2C_SECURITY_CREDENTIAL=""
MPESA_B2C_RESULT_PATH="/api/v1/payments/b2c/result"
MPESA_B2C_QUEUE_TIMEOUT_PATH="/api/v1/payments/b2c/timeout"

# ─── Auth (better-auth) ───
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Google OAuth (for sign-in / sign-up with Google)
# Console: console.cloud.google.com → APIs & Services → Credentials
# Add authorized redirect URI: http://localhost:5111/api/auth/callback/google (dev)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Image storage (S3-compatible) - leave blank to use the local .uploads fallback
STORAGE_ENDPOINT=""
STORAGE_REGION="auto"
STORAGE_BUCKET=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_PUBLIC_BASE_URL=""
STORAGE_LOCAL_DIR=".uploads"

# ─── Postmark (transactional email) ─────────────────────────────────────────
# Leave POSTMARK_TOKEN blank in dev to stub sends to console.log instead.
POSTMARK_TOKEN=""
EMAIL_FROM="noreply@leaders.ke"             # must be a verified sender in Postmark
EMAIL_SUPER_ADMIN="admin@leaders.ke"        # platform inbox for provider signup alerts

# Dev-only login autofill (used only when running `vite dev`) — also the account
# the seed pipeline creates as the system/dev-admin user (see scripts/lib/people.ts).
ADMIN_NAME=""
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

#  AI Chat (Anthropic)
# Leave blank in dev to fall back to keyword-match answers ($lib/server/ai.ts).
ANTHROPIC_API_KEY=""
